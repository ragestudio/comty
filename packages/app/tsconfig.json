{
	"compilerOptions": {
		"target": "ES2023",
		"module": "ESNext",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": false,
		"allowJs": true,
		"checkJs": true,
		"jsx": "react-jsx",
		"noFallthroughCasesInSwitch": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"paths": {
			"@/*": ["./src/*"],
			"@config/*": ["./config/*"],

			"@ui/*": ["./src/ui/*"],
			"@cores/*": ["./src/cores/*"],
			"@pages/*": ["./src/pages/*"],
			"@styles/*": ["./src/styles/*"],
			"@components/*": ["./src/components/*"],
			"@contexts/*": ["./src/contexts/*"],
			"@utils/*": ["./src/utils/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@classes/*": ["./src/classes/*"],
			"@models/*": ["../../modules/comty.js/src/models/*"],

			"comty.js/*": ["../../modules/comty.js/src/*"],
			"vessel/*": ["../../modules/vessel/src/*"],
		},
	},
	"files": ["./src/global.d.ts", "./src/declarations.d.ts"],
	"include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
	"exclude": ["node_modules", "dist", "build"],
}
