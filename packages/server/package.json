{
	"name": "@comty/server",
	"version": "2.15.0@alpha",
	"license": "ComtyLicense",
	"type": "module",
	"private": true,
	"workspaces": [
		"services/*"
	],
	"scripts": {
		"setup": "cross-env NODE_ENV=development linebridge-boot scripts/setup/index.js",
		"start:prod": "cross-env NODE_ENV=production ultragateway",
		"dev": "cross-env NODE_ENV=development DEBUG=true ultragateway",
		"dev:exp": "cross-env NODE_ENV=development DEBUG=true ../../modules/linebridge/linebridge-gateway/debug",
		"preinstall": "bash ./scripts/externalDeps.sh",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@foxify/events": "^2.1.0",
		"@ragestudio/scylla-odm": "^0.21.0",
		"@sentry/node": "^10.57.0",
		"@types/luxon": "^3.7.1",
		"axios": "^1.17.0",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.78.0",
		"cross-env": "^10.1.0",
		"jsonwebtoken": "^9.0.3",
		"linebridge": "link:../../modules/linebridge/server/build",
		"lodash": "^4.18.1",
		"minio": "^8.0.7",
		"mongoose": "^9.7.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.3",
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@vitest/coverage-v8": "^4.1.8",
		"chai": "^6.2.2",
		"eslint": "^10.4.1",
		"globals": "^17.6.0",
		"jest": "^30.4.2",
		"mocha": "12.0.0-beta-9.6",
		"sinon": "^22.0.0",
		"ts-jest": "^29.4.11",
		"vitest": "^4.1.8"
	},
	"optionalDependencies": {
		"bufferutil": "^4.1.0"
	}
}
