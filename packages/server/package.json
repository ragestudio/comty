		"bullmq": "^5.71.0",
		"cassandra-driver": "^4.8.0",
		"cross-env": "^10.1.0",
		"express-cassandra": "^2.9.1",
		"jsonwebtoken": "^9.0.3",
		"jws": "^4.0.1",
		"linebridge": "^1.8.1",
		"lodash": "^4.18.1",
		"minio": "^8.0.7",
		"mongoose": "^9.3.1",
		"qs": "^6.15.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "^29.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
