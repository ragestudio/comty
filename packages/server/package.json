{
	"name": "@comty/server",
	"version": "2.29.0@alpha",
	"license": "ComtyLicense",
	"type": "module",
	"private": true,
	"workspaces": [
		"services/*"
	],
	"aliases": {
		"@comty/shared": "../shared",
		"@db": "../shared/db"
	},
	"scripts": {
		"setup": "cross-env NODE_ENV=development linebridge-boot scripts/setup/index.js",
		"dev": "cross-env NODE_ENV=development DEBUG=true ultragateway",
		"dev:exp": "cross-env NODE_ENV=development DEBUG=true ../../modules/linebridge/linebridge-gateway/debug",
		"preinstall": "bash ./scripts/externalDeps.sh",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@nats-io/jetstream": "^3.4.0",
		"@nats-io/kv": "^3.4.0",
		"@nats-io/transport-node": "^3.4.0",
		"@foxify/events": "^2.1.0",
		"@otplib/uri": "^13.4.1",
		"@ragestudio/scylla-odm": "0.22.17",
		"@sentry/node": "^10.65.0",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.80.4",
		"cross-env": "10.1.0",
		"ioredis": "^5.11.1",
		"jsonwebtoken": "^9.0.3",
		"linebridge": "link:../../modules/linebridge/server/build",
		"lodash": "^4.18.1",
		"minio": "^8.0.7",
		"mongoose": "^9.7.4",
		"otplib": "^13.4.1",
		"qrcode": "^1.5.4",
		"tseep": "^1.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bcrypt": "^6.0.0",
		"@types/jest": "^30.0.0",
		"@types/luxon": "^3.7.2",
		"@types/node": "^25.9.5",
		"@types/qrcode": "^1.5.6",
		"@typescript-eslint/eslint-plugin": "^8.64.0",
		"@vitest/coverage-v8": "^4.1.10",
		"chai": "^6.2.2",
		"eslint": "^10.7.0",
		"globals": "^17.7.0",
		"sinon": "^22.0.0",
		"vitest": "^4.1.10"
	},
	"optionalDependencies": {
		"bufferutil": "^4.1.0"
	}
}
