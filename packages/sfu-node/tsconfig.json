{
	"$schema": "http://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "esnext",
		"module": "CommonJS",
		"moduleResolution": "bundler",
		"strict": false,
		"esModuleInterop": true,
		"allowJs": true,
		"checkJs": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "build",
		"rootDir": "src",
		"types": ["node"],
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
	},
	"include": ["src/**/*.ts"],
}
